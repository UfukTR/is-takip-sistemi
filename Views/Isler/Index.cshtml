@model IEnumerable<IsTakipSistemi.Models.Isler>

@{
    ViewBag.Title = "İşler";
}

<h2>İşler Listesi</h2>
<p>
    @Html.ActionLink("Yeni İş Oluştur", "Create", new { }, new { @class = "btn btn-primary" })
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Başlık</th>
                <th>Açıklama</th>
                <th>Personel</th>
                <th>İletilen Tarih</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count() > 0)
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.IsBaslik)</td>
                        <td>@Html.DisplayFor(modelItem => item.IsAciklama)</td>
                        <td>@item.Personel?.PersonelAdSoyad</td>
                        <td>@item.IletilenTarih?.ToString("dd.MM.yyyy")</td>
                        <td>
                            @if (item.Durum != null)
                            {
                                <span class="badge bg-secondary">@item.Durum.DurumAd</span>
                            }
                        </td>
                        <td>
                            @Html.ActionLink("Detay", "Details", new { id = item.IsId }, new { @class = "btn btn-sm btn-info" })
                            @Html.ActionLink("Düzenle", "Edit", new { id = item.IsId }, new { @class = "btn btn-sm btn-warning" })
                            @Html.ActionLink("Sil", "Delete", new { id = item.IsId }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">Henüz hiç iş oluşturulmamıştır.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
