@model IsTakipSistemi.Models.Isler

@{
    ViewBag.Title = "İş Sil";
}

<h2>İş Sil</h2>

<div class="alert alert-warning" role="alert">
    <strong>Uyarı!</strong> Bu işi silmek üzeresiniz. Bu işlem geri alınamaz.
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h5>@Model.IsBaslik</h5>
            </div>
            <div class="card-body">
                <p><strong>Açıklama:</strong> @Model.IsAciklama</p>
                <p><strong>Personel:</strong> @(Model.Personel?.PersonelAdSoyad ?? "Atanmamış")</p>
                <p><strong>Durum:</strong> @(Model.Durum?.DurumAd ?? "Belirtilmedi")</p>
            </div>
        </div>

        <form method="post" class="mt-3">
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>
