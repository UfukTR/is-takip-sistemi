@model IsTakipSistemi.Models.Durumlar

@{
    ViewBag.Title = "Durum Detayları";
}

<h2>Durum Detayları</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>@Model.DurumAd</h5>
            </div>
            <div class="card-body">
                <p><strong>İş Sayısı:</strong> @Model.Isler.Count</p>
                @if (Model.Isler.Count > 0)
                {
                    <h6>İşler:</h6>
                    <ul>
                        @foreach (var is_ in Model.Isler)
                        {
                            <li>@is_.IsBaslik (@(is_.Personel?.PersonelAdSoyad ?? "Atanmamış"))</li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer">
                @Html.ActionLink("Düzenle", "Edit", new { id = Model.DurumId }, new { @class = "btn btn-warning" })
                @Html.ActionLink("Sil", "Delete", new { id = Model.DurumId }, new { @class = "btn btn-danger" })
                <a href="@Url.Action("Index")" class="btn btn-secondary">Geri Dön</a>
            </div>
        </div>
    </div>
</div>
