@model IsTakipSistemi.Models.Durumlar

@{
    ViewBag.Title = "Yeni Durum Ekle";
}

<h2>Yeni Durum Ekle</h2>

@using (Html.BeginForm("Create", "Durum", FormMethod.Post, new { @class = "form-group" }))
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                @Html.LabelFor(model => model.DurumAd, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.DurumAd, new { @class = "form-control", @placeholder = "Durum Adı" })
                @Html.ValidationMessageFor(model => model.DurumAd, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-success">Ekle</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">İptal</a>
            </div>
        </div>
    </div>
}
