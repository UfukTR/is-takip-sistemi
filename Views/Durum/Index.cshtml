@model IEnumerable<IsTakipSistemi.Models.Durumlar>

@{
    ViewBag.Title = "Durumlar";
}

<h2>Durumlar Listesi</h2>
<p>
    @Html.ActionLink("Yeni Durum Ekle", "Create", new { }, new { @class = "btn btn-primary" })
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Durum Adı</th>
                <th>İş Sayısı</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count() > 0)
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.DurumAd)</td>
                        <td>
                            <span class="badge bg-info">@item.Isler.Count</span>
                        </td>
                        <td>
                            @Html.ActionLink("Detay", "Details", new { id = item.DurumId }, new { @class = "btn btn-sm btn-info" })
                            @Html.ActionLink("Düzenle", "Edit", new { id = item.DurumId }, new { @class = "btn btn-sm btn-warning" })
                            @Html.ActionLink("Sil", "Delete", new { id = item.DurumId }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center">Henüz hiç durum eklenmemiştir.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
