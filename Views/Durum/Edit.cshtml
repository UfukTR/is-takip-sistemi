@model IsTakipSistemi.Models.Durumlar

@{
    ViewBag.Title = "Durum Düzenle";
}

<h2>Durum Düzenle</h2>

@using (Html.BeginForm("Edit", "Durum", FormMethod.Post, new { @class = "form-group" }))
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-6">
            @Html.HiddenFor(model => model.DurumId)

            <div class="mb-3">
                @Html.LabelFor(model => model.DurumAd, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.DurumAd, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.DurumAd, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-warning">Güncelle</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">İptal</a>
            </div>
        </div>
    </div>
}
