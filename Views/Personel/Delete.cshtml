@model IsTakipSistemi.Models.Personeller

@{
    ViewBag.Title = "Personel Sil";
}

<h2>Personel Sil</h2>

<div class="alert alert-warning" role="alert">
    <strong>Uyarı!</strong> Bu personeli silmek üzeresiniz. Bu işlem geri alınamaz.
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h5>@Model.PersonelAdSoyad</h5>
            </div>
            <div class="card-body">
                <p><strong>Kullanıcı Adı:</strong> @Model.PersonelKullaniciAd</p>
                <p><strong>Birim:</strong> @(Model.Birim?.BirimAd ?? "Atanmamış")</p>
                <p><strong>Yetki Türü:</strong> @(Model.YetkiTur?.YetkiTurAd ?? "Belirtilmedi")</p>
            </div>
        </div>

        <form method="post" class="mt-3">
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>
