@model IsTakipSistemi.Models.Personeller

@{
    ViewBag.Title = "Personel Detayları";
}

<h2>Personel Detayları</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>@Model.PersonelAdSoyad</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Kullanıcı Adı:</strong> @Model.PersonelKullaniciAd</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Birim:</strong> @(Model.Birim?.BirimAd ?? "Atanmamış")</p>
                    </div>
                </div>
                <p><strong>Yetki Türü:</strong> @(Model.YetkiTur?.YetkiTurAd ?? "Belirtilmedi")</p>
            </div>
            <div class="card-footer">
                @Html.ActionLink("Düzenle", "Edit", new { id = Model.PersonelId }, new { @class = "btn btn-warning" })
                @Html.ActionLink("Sil", "Delete", new { id = Model.PersonelId }, new { @class = "btn btn-danger" })
                <a href="@Url.Action("Index")" class="btn btn-secondary">Geri Dön</a>
            </div>
        </div>
    </div>
</div>
