@model IsTakipSistemi.Models.Birimler

@{
    ViewBag.Title = "Birim Detayları";
}

<h2>Birim Detayları</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>@Model.BirimAd</h5>
            </div>
            <div class="card-body">
                <p><strong>Personel Sayısı:</strong> @Model.Personeller.Count</p>
                @if (Model.Personeller.Count > 0)
                {
                    <h6>Personeller:</h6>
                    <ul>
                        @foreach (var personel in Model.Personeller)
                        {
                            <li>@personel.PersonelAdSoyad (@personel.PersonelKullaniciAd)</li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer">
                @Html.ActionLink("Düzenle", "Edit", new { id = Model.BirimId }, new { @class = "btn btn-warning" })
                @Html.ActionLink("Sil", "Delete", new { id = Model.BirimId }, new { @class = "btn btn-danger" })
                <a href="@Url.Action("Index")" class="btn btn-secondary">Geri Dön</a>
            </div>
        </div>
    </div>
</div>
