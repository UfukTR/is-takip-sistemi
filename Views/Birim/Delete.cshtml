@model IsTakipSistemi.Models.Birimler

@{
    ViewBag.Title = "Birim Sil";
}

<h2>Birim Sil</h2>

<div class="alert alert-warning" role="alert">
    <strong>Uyarı!</strong> Bu birimi silmek üzeresiniz. Bu işlem geri alınamaz.
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h5>@Model.BirimAd</h5>
            </div>
            <div class="card-body">
                <p><strong>Personel Sayısı:</strong> @Model.Personeller.Count</p>
            </div>
        </div>

        <form method="post" class="mt-3">
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>
